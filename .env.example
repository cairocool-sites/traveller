APP_NAME="Cairo Cool Travel"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ar_EG
APP_TIMEZONE=Africa/Cairo

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cairo_cool_travel
DB_USERNAME=cairo_cool_travel_user
DB_PASSWORD=

# Use file locally if Redis is unavailable. Use redis with SESSION_STORE=redis in production.
SESSION_DRIVER=file
SESSION_STORE=
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis_failover

CACHE_STORE=redis_failover
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE=default
REDIS_QUEUE_CONNECTION=default
REDIS_CACHE_CONNECTION=cache
REDIS_CACHE_LOCK_CONNECTION=default

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

TRAVEL_BRAND_NAME="Cairo Cool Travel"
TRAVEL_PRIMARY_COUNTRY=EG
TRAVEL_DEFAULT_LOCALE=ar
TRAVEL_FALLBACK_LOCALE=en
TRAVEL_TIMEZONE=Africa/Cairo
TRAVEL_DEFAULT_CURRENCY=EGP

ADMIN_NAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Phase 5 supplier foundation uses database-stored encrypted credentials.
# Do not place real supplier endpoints, API keys, usernames, or passwords here.
SUPPLIER_ALLOW_LOCAL_PRIVATE_ENDPOINTS=false

TRAVEL_SEARCH_MAX_ROOMS=4
TRAVEL_SEARCH_MAX_ADULTS_PER_ROOM=4
TRAVEL_SEARCH_MAX_CHILDREN_PER_ROOM=4
TRAVEL_SEARCH_MAX_CHILD_AGE=17
TRAVEL_SEARCH_MAX_STAY_NIGHTS=30
TRAVEL_SEARCH_SESSION_LIFETIME_MINUTES=30
TRAVEL_SEARCH_RESULTS_LIMIT=30

TRAVEL_RATE_CHECK_LIFETIME_MINUTES=20
TRAVEL_BOOKING_DRAFT_LIFETIME_MINUTES=30

TRAVEL_PAYMENT_EVIDENCE_MAX_KB=4096
TRAVEL_PAYMENT_SUBMISSION_EXPIRY_HOURS=24
TRAVEL_PAYMENT_EVIDENCE_DIRECTORY=payment-evidence

TRAVEL_VOUCHER_PREFIX=VCH
TRAVEL_INVOICE_PREFIX=INV
TRAVEL_RECEIPT_PREFIX=RCT
TRAVEL_DOCUMENT_COMPANY_NAME="Cairo Cool Travel"
TRAVEL_DOCUMENT_COMPANY_CONTACT="Contact details will be confirmed before launch."
TRAVEL_DOCUMENT_SHOW_SUPPLIER_CONFIRMATION=false
