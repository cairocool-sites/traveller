APP_NAME="Cairo Cool Travel"
APP_ENV=staging
APP_KEY=
APP_DEBUG=false
APP_URL=https://travel.cairocool.com

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ar_EG
APP_TIMEZONE=Africa/Cairo

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database
TRUSTED_PROXIES=

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_DAILY_DAYS=14
LOG_SUPPLIER_LEVEL=info
LOG_SUPPLIER_DAYS=30
LOG_FINANCIAL_LEVEL=info
LOG_FINANCIAL_DAYS=90
LOG_SECURITY_LEVEL=warning
LOG_SECURITY_DAYS=90

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cairo_cool_travel
DB_USERNAME=cairo_cool_travel_user
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_STORE=
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE=default
REDIS_QUEUE_CONNECTION=default
REDIS_CACHE_CONNECTION=cache
REDIS_CACHE_LOCK_CONNECTION=default

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

TRAVEL_BRAND_NAME="Cairo Cool Travel"
TRAVEL_PRIMARY_COUNTRY=EG
TRAVEL_DEFAULT_LOCALE=ar
TRAVEL_FALLBACK_LOCALE=en
TRAVEL_TIMEZONE=Africa/Cairo
TRAVEL_DEFAULT_CURRENCY=EGP

ADMIN_NAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Phase 5 supplier foundation uses database-stored encrypted credentials.
# Do not place real supplier endpoints, API keys, usernames, or passwords here.
SUPPLIER_ALLOW_LOCAL_PRIVATE_ENDPOINTS=false
HBX_ENABLED=false
HBX_API_KEY=
HBX_API_SECRET=
HBX_BASE_URL=https://api.test.hotelbeds.com
HBX_TIMEOUT=45
HBX_CONNECT_TIMEOUT=15
HBX_INTEGRATION_TESTS=false
HBX_SANDBOX_BOOKING_ENABLED=false
HBX_PRODUCTION_ENABLED=false

TRAVEL_SEARCH_MAX_ROOMS=4
TRAVEL_SEARCH_MAX_ADULTS_PER_ROOM=4
TRAVEL_SEARCH_MAX_CHILDREN_PER_ROOM=4
TRAVEL_SEARCH_MAX_CHILD_AGE=17
TRAVEL_SEARCH_MAX_STAY_NIGHTS=30
TRAVEL_SEARCH_SESSION_LIFETIME_MINUTES=30
TRAVEL_SEARCH_RESULTS_LIMIT=30
TRAVEL_PUBLIC_SEARCH_SUPPLIERS=hbx_hotels
TRAVEL_PUBLIC_SEARCH_MARKUP_BASIS_POINTS=0

TRAVEL_RATE_CHECK_LIFETIME_MINUTES=20
TRAVEL_BOOKING_DRAFT_LIFETIME_MINUTES=30
TRAVEL_BOOKING_SUBMISSION_MODE=manual_review

TRAVEL_PAYMENT_EVIDENCE_MAX_KB=4096
TRAVEL_PAYMENT_SUBMISSION_EXPIRY_HOURS=24
TRAVEL_PAYMENT_EVIDENCE_DIRECTORY=payment-evidence
TRAVEL_PAYMENT_LIVE_ENABLED=false

TRAVEL_VOUCHER_PREFIX=VCH
TRAVEL_INVOICE_PREFIX=INV
TRAVEL_RECEIPT_PREFIX=RCT
TRAVEL_DOCUMENT_COMPANY_NAME="Cairo Cool Travel"
TRAVEL_DOCUMENT_COMPANY_CONTACT="Contact details will be confirmed before launch."
TRAVEL_DOCUMENT_SHOW_SUPPLIER_CONFIRMATION=false

TRAVEL_CANCELLATION_REQUEST_LIFETIME_HOURS=24
TRAVEL_CANCELLATION_RATE_LIMIT=6,1
TRAVEL_AUTO_SUPPLIER_CANCEL_MOCK=true
TRAVEL_ACTUAL_SUPPLIER_CANCELLATION_ENABLED=false
TRAVEL_CANCELLATION_MANUAL_REVIEW_THRESHOLD_MINOR=1000000
TRAVEL_REFUND_REFERENCE_PREFIX=RFD
TRAVEL_REFUND_MAX_AGE_DAYS=180
TRAVEL_REFUND_PROCESSING_MESSAGE="Refunds are tracked manually and may take time to process."

TRAVEL_CSP_REPORT_ONLY=true
TRAVEL_RATE_LIMIT_HEALTH_PER_MINUTE=30
TRAVEL_RATE_LIMIT_SEARCH_PER_MINUTE=30
TRAVEL_RATE_LIMIT_BOOKING_PER_MINUTE=10
TRAVEL_RATE_LIMIT_PAYMENT_PER_MINUTE=6
TRAVEL_RATE_LIMIT_EVIDENCE_PER_MINUTE=20
TRAVEL_RATE_LIMIT_DOCUMENT_VERIFY_PER_MINUTE=30
TRAVEL_RATE_LIMIT_CANCELLATION_PER_MINUTE=6
TRAVEL_RATE_LIMIT_STATUS_PER_MINUTE=30
TRAVEL_SCHEDULER_STALE_AFTER_MINUTES=5
TRAVEL_RETENTION_SUPPLIER_LOGS_DAYS=90
TRAVEL_RETENTION_SEARCH_SESSIONS_DAYS=2
TRAVEL_RETENTION_RATE_CHECKS_DAYS=2
TRAVEL_RETENTION_BOOKING_DRAFTS_DAYS=7
TRAVEL_RETENTION_NOTIFICATIONS_DAYS=180
TRAVEL_RETENTION_TEMP_UPLOADS_DAYS=2
TRAVEL_SUPPLIER_SOAP_ENABLED=false
TRAVEL_ALLOW_SYNC_QUEUE_IN_PRODUCTION=false
